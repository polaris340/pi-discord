# Discord bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord User ID (optional — if unset, anyone can use the bot)
ALLOWED_USER_ID=

# pi authentication:
#   Run once to log in via TUI:  docker compose run --rm pi-discord pi
#   Credentials are persisted in ./sessions/
#
# Model/settings can be changed from Discord:
#   !model              — cycle to next model
#   !model anthropic claude-sonnet-4-6  — set specific model
#   !help               — list all commands
